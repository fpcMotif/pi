{
	"name": "@earendil-works/pi-agent-core",
	"version": "0.74.0",
	"description": "General-purpose agent with transport abstraction, state management, and attachment support",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"clean": "rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
		"test": "vitest --run",
		"test:coverage": "vitest --run --coverage --no-file-parallelism --maxWorkers=1 --minWorkers=1",
		"test:coverage:100": "vitest --run --coverage --no-file-parallelism --maxWorkers=1 --minWorkers=1 --coverage.thresholds.lines=100 --coverage.thresholds.branches=100 --coverage.thresholds.functions=100 --coverage.thresholds.statements=100",
		"test:effect": "vitest --run test/effect",
		"test:coverage:effect": "vitest --run test/effect --coverage --no-file-parallelism --maxWorkers=1 --minWorkers=1",
		"check:effect": "tsgo -p tsconfig.build.json --noEmit",
		"lint:effect": "oxlint test-support test/effect",
		"fmt:effect": "oxfmt test-support test/effect CONTEXT.md",
		"fmt:effect:check": "oxfmt --check test-support test/effect CONTEXT.md",
		"prepublishOnly": "bun run clean && bun run build"
	},
	"dependencies": {
		"@earendil-works/pi-ai": "^0.74.0",
		"@effect/ai-openai": "4.0.0-beta.65",
		"effect": "4.0.0-beta.65",
		"ignore": "^7.0.5",
		"typebox": "^1.1.24",
		"uuid": "^14.0.0",
		"yaml": "^2.8.2"
	},
	"keywords": [
		"ai",
		"agent",
		"llm",
		"transport",
		"state-management"
	],
	"author": "Mario Zechner",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/earendil-works/pi-mono.git",
		"directory": "packages/agent"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"devDependencies": {
		"@effect/vitest": "4.0.0-beta.65",
		"@types/node": "^24.3.0",
		"oxfmt": "^0.49.0",
		"oxlint": "1.42.0",
		"typescript": "^5.7.3",
		"vitest": "^3.2.4"
	}
}

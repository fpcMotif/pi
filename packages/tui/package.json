{
	"name": "@earendil-works/pi-tui",
	"version": "0.74.0",
	"description": "Terminal User Interface library with differential rendering for efficient text-based applications",
	"type": "module",
	"main": "dist/index.js",
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
		"test": "vitest --run",
		"test:coverage": "vitest --run --coverage --no-file-parallelism --maxWorkers=1 --minWorkers=1",
		"test:coverage:100": "vitest --run --coverage --no-file-parallelism --maxWorkers=1 --minWorkers=1 --coverage.thresholds.lines=100 --coverage.thresholds.branches=100 --coverage.thresholds.functions=100 --coverage.thresholds.statements=100",
		"prepublishOnly": "bun run clean && bun run build"
	},
	"files": [
		"dist/**/*",
		"README.md"
	],
	"keywords": [
		"tui",
		"terminal",
		"ui",
		"text-editor",
		"differential-rendering",
		"typescript",
		"cli"
	],
	"author": "Mario Zechner",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/earendil-works/pi-mono.git",
		"directory": "packages/tui"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"types": "./dist/index.d.ts",
	"dependencies": {
		"@types/mime-types": "^2.1.4",
		"chalk": "^5.5.0",
		"get-east-asian-width": "^1.3.0",
		"marked": "^15.0.12",
		"mime-types": "^3.0.1"
	},
	"optionalDependencies": {
		"koffi": "^2.9.0"
	},
	"devDependencies": {
		"@vitest/coverage-v8": "^3.2.4",
		"@xterm/headless": "^5.5.0",
		"@xterm/xterm": "^5.5.0",
		"vitest": "^3.2.4"
	}
}

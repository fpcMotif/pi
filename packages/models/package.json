{
	"name": "@earendil-works/pi-models",
	"version": "0.74.0",
	"description": "Pure model-registry data and synchronous utilities for pi-mono. No Effect or provider runtime dependencies; browser-safe.",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"clean": "rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
		"test": "vitest --run",
		"test:coverage": "vitest --run --coverage --no-file-parallelism --maxWorkers=1 --minWorkers=1",
		"test:coverage:100": "vitest --run --coverage --no-file-parallelism --maxWorkers=1 --minWorkers=1 --coverage.thresholds.lines=100 --coverage.thresholds.branches=100 --coverage.thresholds.functions=100 --coverage.thresholds.statements=100",
		"prepublishOnly": "bun run clean && bun run build"
	},
	"keywords": [
		"pi",
		"ai",
		"llm",
		"model-registry"
	],
	"author": "Mario Zechner",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/earendil-works/pi-mono.git",
		"directory": "packages/models"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"devDependencies": {
		"@types/node": "^24.3.0",
		"@vitest/coverage-v8": "^3.2.4",
		"vitest": "^3.2.4"
	}
}
